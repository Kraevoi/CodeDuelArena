@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Таблица лидеров";
}

<h2 class="text-danger">🏆 ТАБЛИЦА ЛИДЕРОВ</h2>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr>
                <th>#</th>
                <th>ИГРОК</th>
                <th>⭐ ОЧКИ</th>
                <th>🏆 ПОБЕДЫ</th>
                <th>💀 ПОРАЖЕНИЯ</th>
                <th>✅ КВЕСТЫ</th>
                <th>📅 РЕГИСТРАЦИЯ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                for (int i = 0; i < Model.Count; i++)
                {
                    <tr>
                        <td class="fw-bold">@(i + 1)</td>
                        <td>@Model[i].Username</td>
                        <td class="text-danger fw-bold">@Model[i].Score</td>
                        <td>@Model[i].Wins</td>
                        <td>@Model[i].Losses</td>
                        <td>@Model[i].CompletedQuests</td>
                        <td>@Model[i].RegisteredAt.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Нет игроков</td>
                </tr>
            }
        </tbody>
    </table>
</div>