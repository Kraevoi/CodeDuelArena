@model List<CodeDuelArena.Models.UserModel>
<h2 class="text-danger">🏆 ТАБЛИЦА</h2>
<table class="table table-dark">
    <tr><th>#</th><th>Игрок</th><th>Очки</th><th>Победы</th><th>Квесты</th></tr>
    @for(int i=0;i<Model.Count;i++)
    {
        <tr><td>@(i+1)</td><td>@Model[i].Username</td><td>@Model[i].Score</td><td>@Model[i].Wins</td><td>@Model[i].CompletedQuests.Count</td></tr>
    }
</table>