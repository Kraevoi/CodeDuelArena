@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Таблица лидеров";
}

<h2 class="text-danger">🏆 ТАБЛИЦА ЛИДЕРОВ</h2>
<table class="table table-dark table-striped">
    <thead class="bg-danger">
        <tr><th>#</th><th>Игрок</th><th>⭐ Очки</th><th>🏆 Победы</th><th>💀 Поражения</th><th>✅ Квесты</th><th>📅 Регистрация</th></tr>
    </thead>
    <tbody>
        @for(int i=0; i<Model.Count; i++)
        {
            <tr>
                <td>@(i+1)</td>
                <td>@Model[i].Username</td>
                <td class="text-danger fw-bold">@Model[i].Score</td>
                <td>@Model[i].Wins</td>
                <td>@Model[i].Losses</td>
                <td>@Model[i].CompletedQuests.Count</td>
                <td>@Model[i].RegisteredAt.ToString("dd.MM.yyyy")</td>
            </tr>
        }
    </tbody>
</table>