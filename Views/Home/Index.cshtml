@{
    ViewData["Title"] = "Арена";
}
<h1 class="text-danger">⚔️ CODE DUEL ARENA</h1>
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card bg-dark">
            <div class="card-header bg-danger">🔥 Статистика</div>
            <div class="card-body" id="userStats">Войдите чтобы видеть статистику</div>
            <button id="duelQueueBtn" class="btn btn-danger">⚔️ В очередь на дуэль</button>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-dark">
            <div class="card-header bg-danger">📢 Жалоба</div>
            <div class="card-body">
                <form method="post" action="/Home/ReportBug">
                    <textarea name="bugText" class="form-control" rows="3"></textarea>
                    <button type="submit" class="btn btn-danger mt-2">Отправить</button>
                </form>
            </div>
        </div>
    </div>
</div>
<div class="mt-4"><h3>🏆 ТАБЛИЦА</h3><div id="leaderboardTable"></div></div>
<script>
    $("#duelQueueBtn").click(() => connection?.invoke("JoinDuelQueue"));
    setInterval(() => { if(currentUser) $("#userStats").html(`Ник: ${currentUser.username}<br>Очки: ${currentUser.score}<br>Победы: ${currentUser.wins}<br>Квестов: ${currentUser.completedQuests?.length || 0}`); }, 500);
</script>