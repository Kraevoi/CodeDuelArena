@{
    ViewData["Title"] = "Арена";
}

<div class="text-center">
    <h1 class="display-4 text-danger fw-bold">⚔️ CODE DUEL ARENA</h1>
    <p class="lead text-info">Исправляй легаси, взламывай, уничтожай оппонентов.</p>
    
    <div class="row mt-5">
        <div class="col-md-6">
            <div class="card bg-dark border-danger mb-4">
                <div class="card-header bg-danger text-white fw-bold">
                    🔥 ТВОЯ СТАТИСТИКА
                </div>
                <div class="card-body" id="userStats">
                    <div class="text-center text-muted">
                        <p>Войди в систему, чтобы видеть свои данные</p>
                        <i class="text-info">Введи никнейм в правом верхнем углу</i>
                    </div>
                </div>
                <div class="card-footer">
                    <button id="duelQueueBtn" class="btn btn-danger w-100 mt-2">
                         ⚔️ ВСТАТЬ В ОЧЕРЕДЬ НА ДУЭЛЬ
                    </button>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card bg-dark border-danger">
                <div class="card-header bg-danger text-white fw-bold">
                    📢 ЖАЛОБА / БАГ
                </div>
                <div class="card-body">
                    <form method="post" asp-action="ReportBug">
                        <textarea name="bugText" class="form-control bg-black text-white border-danger" rows="4" placeholder="Опиши проблему или баг..."></textarea>
                        <button type="submit" class="btn btn-danger mt-3 w-100">
                            🚨 ОТПРАВИТЬ ЖАЛОБУ
                        </button>
                    </form>
                    @if(TempData["ReportMessage"] != null)
                    {
                        <div class="alert alert-info mt-3 mb-0">
                            @TempData["ReportMessage"]
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-5">
        <h3 class="text-danger fw-bold">🏆 ТАБЛИЦА ЛИДЕРОВ</h3>
        <div id="leaderboardTable" class="mt-3">
            <div class="text-center text-muted">Загрузка...</div>
        </div>
    </div>
</div>

<script>
    if(window.connection && window.currentUser) {
        setInterval(() => {
            if(window.currentUser) {
                document.getElementById('userStats').innerHTML = `
                    <div class="text-start">
                        <p><span class="text-danger fw-bold">👤 Ник:</span> ${window.currentUser.username}</p>
                        <p><span class="text-danger fw-bold">⭐ Очки:</span> ${window.currentUser.score}</p>
                        <p><span class="text-danger fw-bold">🏆 Победы:</span> ${window.currentUser.wins}</p>
                        <p><span class="text-danger fw-bold">💀 Поражения:</span> ${window.currentUser.losses}</p>
                        <p><span class="text-danger fw-bold">✅ Квестов пройдено:</span> ${window.currentUser.completedQuests.length}</p>
                    </div>
                `;
            }
        }, 1000);
    }
</script>