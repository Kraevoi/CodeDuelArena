<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeDuel Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body style="background: #0a0a0a; color: #fff;">
    <nav class="navbar navbar-dark bg-dark border-bottom border-danger">
        <div class="container-fluid">
            <a class="navbar-brand text-danger fw-bold" href="/">⚔️ CODE DUEL</a>
            <div>
                <a href="/Home/Quests" class="btn btn-outline-danger me-2">Квесты</a>
                <a href="/Home/Leaderboard" class="btn btn-outline-danger me-2">Таблица</a>
                <a href="/Admin/Login" class="btn btn-outline-warning btn-sm me-2">Admin</a>
                <span id="userInfo" class="text-white me-2 d-none">
                    <span id="userNameDisplay"></span>
                    <span id="userScoreDisplay" class="ms-2"></span>
                    <button id="logoutBtn" class="btn btn-sm btn-outline-danger ms-2">Выйти</button>
                </span>
                <button id="showAuthBtn" class="btn btn-danger">Войти</button>
            </div>
        </div>
    </nav>
    <div class="container mt-4">@RenderBody()</div>
    @await Html.PartialAsync("_SignalRChat")
    @await Html.PartialAsync("_AuthModal")
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/duel.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>