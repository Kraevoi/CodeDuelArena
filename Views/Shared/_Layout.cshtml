<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeDuel Arena</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="CodeDuel">
    <link rel="apple-touch-icon" href="/icon-192.png">
    <style>
        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a0a0a 100%);
            color: #fff;
            font-family: 'Courier New', monospace;
        }
        .navbar {
            border-bottom: 2px solid #dc3545;
            background: #000 !important;
        }
        .card {
            background: #111;
            border: 1px solid #dc3545;
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 20px rgba(220, 53, 69, 0.3);
        }
        pre {
            background: #000;
            padding: 10px;
            border-left: 3px solid #dc3545;
            overflow-x: auto;
            color: #ffc107;
        }
        .btn-danger {
            background: #dc3545;
            border: none;
            font-weight: bold;
        }
        .btn-danger:hover {
            background: #bb2d3b;
            transform: scale(1.02);
        }
        .btn-outline-danger {
            border: 1px solid #dc3545;
            color: #dc3545;
        }
        .btn-outline-danger:hover {
            background: #dc3545;
            color: #fff;
        }
        .form-control {
            background: #000;
            color: #fff;
            border: 1px solid #dc3545;
        }
        .form-control:focus {
            background: #1a1a1a;
            color: #fff;
            border-color: #dc3545;
            box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
        }
        .table {
            color: #fff;
        }
        .table-dark {
            background: #111;
        }
        .table thead th {
            background: #dc3545;
            color: white;
            border-bottom: none;
        }
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #000;
        }
        ::-webkit-scrollbar-thumb {
            background: #dc3545;
        }
        .text-danger {
            color: #dc3545 !important;
        }
        .bg-black {
            background: #000 !important;
        }
        .border-danger {
            border-color: #dc3545 !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand text-danger fw-bold fs-3" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-code"></i> CODE DUEL
            </a>
            <div>
                <a class="btn btn-outline-danger me-2" asp-controller="Home" asp-action="Quests">Квесты</a>
                <a class="btn btn-outline-danger me-2" asp-controller="Home" asp-action="Leaderboard">Таблица</a>
                <a class="btn btn-outline-warning btn-sm me-2" asp-controller="Admin" asp-action="Login">Admin</a>
                <span id="userInfo" class="text-white me-2 d-none">
                    <span id="userNameDisplay" class="text-danger"></span>
                    <span id="userScoreDisplay" class="ms-2"></span>
                    <button id="logoutBtn" class="btn btn-sm btn-outline-danger ms-2">Выйти</button>
                </span>
                <button id="showAuthBtn" class="btn btn-danger">Войти</button>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    @await Html.PartialAsync("_SignalRChat")
    @await Html.PartialAsync("_AuthModal")
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/duel.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>