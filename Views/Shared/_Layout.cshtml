<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeDuel Arena</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand text-danger fw-bold fs-3" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-code"></i> CODE DUEL
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-arena"></i> Арена
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Quests">
                                <i class="fas fa-tasks"></i> Квесты
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="Leaderboard">
                                <i class="fas fa-trophy"></i> Таблица
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex" id="authPanel">
                        <div id="userInfo" class="d-none me-3">
                            <span class="text-danger" id="userNameDisplay"></span>
                            <span class="text-white ms-2" id="userScoreDisplay"></span>
                            <button id="logoutBtn" class="btn btn-sm btn-outline-danger ms-2">Выйти</button>
                        </div>
                        <button id="showAuthBtn" class="btn btn-outline-danger">
                            <i class="fas fa-user"></i> Войти
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid mt-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    
    <footer class="border-top border-danger text-center py-3 mt-5">
        <small class="text-muted">
            <i class="fas fa-skull"></i> CodeDuel Arena — Swill Way, 2026 <i class="fas fa-dragon"></i>
        </small>
    </footer>
    
    @await Html.PartialAsync("_SignalRChat")
    @await Html.PartialAsync("_AuthModal")
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script src="~/js/duel.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>