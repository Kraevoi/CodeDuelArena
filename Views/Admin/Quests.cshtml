@model List<CodeDuelArena.Models.QuestModel>
@{
    ViewData["Title"] = "Quests";
}

<h2 class="text-danger">📋 УПРАВЛЕНИЕ КВЕСТАМИ</h2>
<div class="mb-3"><a href="/Admin/AddQuest" class="btn btn-danger">➕ Добавить квест</a> <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a></div>

<table class="table table-dark table-striped">
    <thead class="bg-danger"><tr><th>ID</th><th>Название</th><th>Тип</th><th>Очки</th><th>Действие</th></tr></thead>
    <tbody>
        @foreach(var q in Model)
        {
            <tr>
                <td>@q.Id</td><td>@q.Title</td><td><span class="badge bg-@(q.Type=="LegacyFix"?"danger":"primary")">@q.Type</span></td><td>@q.Points</td>
                <td><button class="btn btn-sm btn-danger" onclick="deleteQuest(@q.Id)">Удалить</button></td>
            </tr>
        }
    </tbody>
</table>

<script>
    function deleteQuest(id) { if(confirm("Удалить квест?")) $.post("/Admin/DeleteQuest", { id: id }, () => location.reload()); }
</script>