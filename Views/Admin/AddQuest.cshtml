@model CodeDuelArena.Models.QuestModel
@{
    ViewData[""Title""] = ""Add Quest"";
}
<h2 class=""text-danger"">Добавить квест</h2>
<form method=""post"">
    <div class=""mb-2""><label>Название</label><input asp-for=""Title"" class=""form-control"" required /></div>
    <div class=""mb-2""><label>Тип</label><select asp-for=""Type"" class=""form-control""><option>LegacyFix</option><option>Hack</option></select></div>
    <div class=""mb-2""><label>Описание</label><textarea asp-for=""Description"" class=""form-control"" rows=""3"" required></textarea></div>
    <div class=""mb-2""><label>Код</label><textarea asp-for=""LegacyCode"" class=""form-control"" rows=""5"" required></textarea></div>
    <div class=""mb-2""><label>Решение</label><textarea asp-for=""SolutionCode"" class=""form-control"" rows=""5"" required></textarea></div>
    <div class=""mb-2""><label>Очки</label><input asp-for=""Points"" type=""number"" class=""form-control"" required /></div>
    <button type=""submit"" class=""btn btn-danger"">Добавить</button>
</form>
