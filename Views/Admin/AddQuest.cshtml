@model CodeDuelArena.Models.QuestModel
@{
    ViewData["Title"] = "Add Quest";
}

<h2 class="text-danger">➕ ДОБАВЛЕНИЕ КВЕСТА</h2>
@Html.ActionLink("← Назад", "Quests", "Admin", null, new { @class = "btn btn-outline-danger mb-3" })

@if (TempData["Message"] != null)
{
    @Html.Raw($"<div class='alert alert-success'>{TempData["Message"]}</div>")
}

<div class="card bg-dark">
    <div class="card-body">
        @using (Html.BeginForm("AddQuest", "Admin", FormMethod.Post))
        {
            <div class="mb-2">
                @Html.LabelFor(m => m.Title, new { @class = "text-danger" })
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control bg-black text-white", required = "required" })
                @Html.ValidationMessageFor(m => m.Title, null, new { @class = "text-danger" })
            </div>
            <div class="mb-2">
                @Html.LabelFor(m => m.Type, new { @class = "text-danger" })
                @Html.DropDownListFor(m => m.Type, new SelectList(new[] { "LegacyFix", "Hack" }), new { @class = "form-control bg-black text-white" })
                @Html.ValidationMessageFor(m => m.Type, null, new { @class = "text-danger" })
            </div>
            <div class="mb-2">
                @Html.LabelFor(m => m.Description, new { @class = "text-danger" })
                @Html.TextAreaFor(m => m.Description, new { @class = "form-control bg-black text-white", rows = 3, required = "required" })
                @Html.ValidationMessageFor(m => m.Description, null, new { @class = "text-danger" })
            </div>
            <div class="mb-2">
                @Html.LabelFor(m => m.LegacyCode, new { @class = "text-danger" })
                @Html.TextAreaFor(m => m.LegacyCode, new { @class = "form-control bg-black text-white", rows = 5, required = "required" })
                @Html.ValidationMessageFor(m => m.LegacyCode, null, new { @class = "text-danger" })
            </div>
            <div class="mb-2">
                @Html.LabelFor(m => m.SolutionCode, new { @class = "text-danger" })
                @Html.TextAreaFor(m => m.SolutionCode, new { @class = "form-control bg-black text-white", rows = 5, required = "required" })
                @Html.ValidationMessageFor(m => m.SolutionCode, null, new { @class = "text-danger" })
            </div>
            <div class="mb-2">
                @Html.LabelFor(m => m.Points, new { @class = "text-danger" })
                @Html.TextBoxFor(m => m.Points, new { @class = "form-control bg-black text-white", type = "number", required = "required" })
                @Html.ValidationMessageFor(m => m.Points, null, new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-danger w-100">➕ Добавить</button>
        }
    </div>
</div>