@model CodeDuelArena.Models.QuestModel
@{
    ViewData["Title"] = "Add Quest";
}

<h2 class="text-danger">➕ ДОБАВЛЕНИЕ КВЕСТА</h2>
<a href="/Admin/Quests" class="btn btn-outline-danger mb-3">← Назад</a>

@if(TempData["Message"] != null){ <div class="alert alert-success">@TempData["Message"]</div> }

<div class="card bg-dark">
    <div class="card-body">
        <form method="post">
            <div class="mb-2"><label class="text-danger">Название</label><input asp-for="Title" class="form-control bg-black text-white" required /></div>
            <div class="mb-2"><label class="text-danger">Тип</label><select asp-for="Type" class="form-control bg-black text-white"><option value="LegacyFix">Легаси-код</option><option value="Hack">Взлом</option></select></div>
            <div class="mb-2"><label class="text-danger">Описание</label><textarea asp-for="Description" class="form-control bg-black text-white" rows="3" required></textarea></div>
            <div class="mb-2"><label class="text-danger">Код для исправления</label><textarea asp-for="LegacyCode" class="form-control bg-black text-white" rows="5" required></textarea></div>
            <div class="mb-2"><label class="text-danger">Правильное решение</label><textarea asp-for="SolutionCode" class="form-control bg-black text-white" rows="5" required></textarea></div>
            <div class="mb-2"><label class="text-danger">Очки</label><input asp-for="Points" type="number" class="form-control bg-black text-white" required /></div>
            <button type="submit" class="btn btn-danger w-100">➕ Добавить</button>
        </form>
    </div>
</div>