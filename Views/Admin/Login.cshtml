@{
    ViewData["Title"] = "Admin Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card bg-dark border-danger">
            <div class="card-header bg-danger text-center">🔐 ADMIN PANEL</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(ViewBag.Error))
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                <form method="post">
                    <input type="password" name="password" class="form-control bg-black text-white border-danger mb-3" placeholder="Admin Password" required>
                    <div class="form-check mb-3">
                        <input type="checkbox" name="rememberMe" class="form-check-input">
                        <label class="form-check-label">Запомнить меня</label>
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Войти</button>
                </form>
            </div>
        </div>
    </div>
</div>