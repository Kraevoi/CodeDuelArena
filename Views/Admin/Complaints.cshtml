@model List<CodeDuelArena.Models.Complaint>
@{
    ViewData["Title"] = "Complaints";
}

<h2 class="text-danger">📢 Жалобы</h2>

<div class="mb-3">
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr><th>ID</th><th>Пользователь</th><th>Сообщение</th><th>Дата</th><th>Статус</th><th>Действие</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Id</td
                    <td>@c.UserName</td
                    <td>@c.Message</td
                    <td>@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td
                    <td>@(c.IsRead ? "✅ Прочитано" : "🆕 Новое")</td
                    <td>
                        @if (!c.IsRead)
                        {
                            <button class="btn btn-sm btn-success" onclick="markRead(@c.Id)">✓ Прочитано</button>
                        }
                        <button class="btn btn-sm btn-danger" onclick="deleteComplaint(@c.Id)">🗑 Удалить</button>
                     </td
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function markRead(id) {
        $.post("/Admin/MarkRead", { id: id }, function() { location.reload(); });
    }
    function deleteComplaint(id) {
        if (confirm("Удалить жалобу?")) {
            $.post("/Admin/DeleteComplaint", { id: id }, function() { location.reload(); });
        }
    }
</script>