@model List<CodeDuelArena.Models.Complaint>
@{
    ViewData["Title"] = "Complaints";
}

<h2 class="text-danger">📢 Жалобы</h2>

<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>

<table class="table table-dark">
    <thead class="bg-danger">
        <tr><th>ID</th><th>Пользователь</th><th>Сообщение</th><th>Дата</th><th>Статус</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <td>
                <td>@c.Id</td
                <td>@c.UserName</td
                <td>@c.Message</td
                <td>@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td
                <td>@(c.IsRead ? "✅" : "🆕")</td
                <td>
                    @if (!c.IsRead) { <button class="btn btn-sm btn-success" onclick="markRead(@c.Id)">✓</button> }
                    <button class="btn btn-sm btn-danger" onclick="deleteComplaint(@c.Id)">🗑</button>
                 </td>
            </td>
            
        }
    </tbody>
</table>

<script>
function markRead(id) { $.post("/Admin/MarkRead", { id: id }, () => location.reload()); }
function deleteComplaint(id) { if(confirm("Удалить?")) $.post("/Admin/DeleteComplaint", { id: id }, () => location.reload()); }
</script>