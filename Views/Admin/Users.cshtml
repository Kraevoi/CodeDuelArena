@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Users";
}

<h2 class="text-danger">👥 Пользователи</h2>

<div class="mb-3">
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Email</th>
                <th>⭐ Очки</th>
                <th>🏆 Победы</th>
                <th>💀 Поражения</th>
                <th>Действие</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td
                    <td>@u.Username</td
                    <td>@u.Email</td
                    <td class="text-danger fw-bold">@u.Score</td
                    <td>@u.Wins</td
                    <td>@u.Losses</td
                    <td>
                        @if (!u.IsAdmin)
                        {
                            <a href="/Admin/Impersonate?id=@u.Id" class="btn btn-sm btn-warning">Войти</a>
                        }
                     </td
                </tr>
            }
        </tbody>
    </table>
</div>