@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Users";
}

<h2 class="text-danger">👥 Пользователи</h2>

<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>

<table class="table table-dark">
    <thead class="bg-danger">
        <tr><th>ID</th><th>Имя</th><th>Email</th><th>Очки</th><th>Победы</th><th>Поражения</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td
                <td>@u.Username</td
                <td>@u.Email</td
                <td class="text-danger">@u.Score</td
                <td>@u.Wins</td
                <td>@u.Losses</td
                <td><a href="/Admin/Impersonate?id=@u.Id" class="btn btn-sm btn-warning">Войти</a></td
            </tr>
        }
    </tbody>
</table>