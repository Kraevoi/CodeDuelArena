@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Users";
}

<h2 class="text-danger">👥 УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ</h2>
<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr>
                <th>ID</th>
                <th>Имя</th>
                <th>Email</th>
                <th>Очки</th>
                <th>Победы</th>
                <th>Поражения</th>
                <th>Действие</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.Username</td>
                        <td>@u.Email</td>
                        <td class="text-danger fw-bold">@u.Score</td>
                        <td>@u.Wins</td>
                        <td>@u.Losses</td>
                        <td>
                            <button class="btn btn-sm btn-danger" onclick="deleteUser(@u.Id, '@u.Username')">Удалить</button>
                         </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Нет пользователей</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function deleteUser(id, name) {
        if (confirm(`Удалить пользователя ${name}?`)) {
            $.post("/Admin/DeleteUser", { id: id }, function() {
                location.reload();
            });
        }
    }
</script>