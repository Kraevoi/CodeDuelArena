@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData[""Title""] = ""Users"";
}
<h2 class=""text-danger"">Пользователи</h2>
<table class=""table table-dark"">
    <thead><tr><th>ID</th><th>Имя</th><th>Email</th><th>Очки</th><th>Действие</th></tr></thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr><td>@u.Id</td><td>@u.Username</td><td>@u.Email</td><td>@u.Score</td>
            <td><button class=""btn btn-sm btn-danger"" onclick=""deleteUser(@u.Id)"">Удалить</button></td></tr>
        }
    </tbody>
</table>
<script>
function deleteUser(id) {
    if(confirm(""Удалить?"")) $.post(""/Admin/DeleteUser"", { id: id }, () => location.reload());
}
</script>
