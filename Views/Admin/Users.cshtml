@model List<CodeDuelArena.Models.UserDb>
@using CodeDuelArena.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@{
    ViewData["Title"] = "Users";
    
    // Получаем аватарки
    var avatars = await Db.UserSettings.ToDictionaryAsync(s => s.Username, s => s.AvatarUrl);
}

<h2 class="text-danger">👥 Управление пользователями</h2>

<div class="mb-3">
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr>
                <th>ID</th>
                <th>Аватар</th>
                <th>Имя</th>
                <th>Email</th>
                <th>⭐ Очки</th>
                <th>🏆 Победы</th>
                <th>💀 Поражения</th>
                <th>👑 Админ</th>
                <th>Действие</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td
                    <td>
                        @if (avatars.ContainsKey(u.Username) && !string.IsNullOrEmpty(avatars[u.Username]))
                        {
                            <img src="@avatars[u.Username]" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;">
                        }
                        else
                        {
                            <div style="width: 40px; height: 40px; background: #dc3545; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                                @u.Username[0]
                            </div>
                        }
                     </td
                    <td>@u.Username</td
                    <td>@u.Email</td
                    <td class="text-danger fw-bold">@u.Score</td
                    <td>@u.Wins</td
                    <td>@u.Losses</td
                    <td>@(u.IsAdmin ? "✅" : "❌")</td
                    <td>
                        @if (!u.IsAdmin)
                        {
                            <a href="/Admin/Impersonate?id=@u.Id" class="btn btn-sm btn-warning">Войти</a>
                        }
                     </td
                </tr>
            }
        </tbody>
    </table>
</div>