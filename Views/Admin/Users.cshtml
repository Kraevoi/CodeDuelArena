@model List<CodeDuelArena.Models.UserDb>
@{
    ViewData["Title"] = "Users";
}

<h2 class="text-danger">👥 УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ</h2>
<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>

<table class="table table-dark table-striped">
    <thead class="bg-danger"><tr><th>ID</th><th>Имя</th><th>Email</th><th>Очки</th><th>Победы</th><th>Поражения</th><th>Квесты</th><th>Действие</th></tr></thead>
    <tbody>
        @foreach(var u in Model)
        {
            <tr>
                <td>@u.Id</td><td>@u.Username</td><td>@u.Email</td><td class="text-danger">@u.Score</td><td>@u.Wins</td><td>@u.Losses</td><td>@u.CompletedQuests.Count</td>
                <td><button class="btn btn-sm btn-danger" onclick="deleteUser(@u.Id, '@u.Username')">Удалить</button></td>
            </tr>
        }
    </tbody>
</table>

<script>
    function deleteUser(id, name) {
        if(confirm(`Удалить ${name}?`)) $.post("/Admin/DeleteUser", { id: id }, () => location.reload());
    }
</script>