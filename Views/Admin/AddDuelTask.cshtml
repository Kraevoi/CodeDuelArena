@model CodeDuelArena.Models.DuelTask
@{
    ViewData["Title"] = "Add Duel Task";
}

<h2 class="text-danger">➕ ДОБАВЛЕНИЕ ЗАДАНИЯ ДЛЯ ДУЭЛИ</h2>
@Html.ActionLink("← Назад", "DuelTasks", "Admin", null, new { @class = "btn btn-outline-danger mb-3" })

<div class="card bg-dark">
    <div class="card-body">
        @using (Html.BeginForm("AddDuelTask", "Admin", FormMethod.Post))
        {
            <div class="mb-3">
                @Html.LabelFor(m => m.Title, new { @class = "form-label text-danger" })
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control bg-black text-white", required = "required" })
                @Html.ValidationMessageFor(m => m.Title, null, new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Description, new { @class = "form-label text-danger" })
                @Html.TextAreaFor(m => m.Description, new { @class = "form-control bg-black text-white", rows = 3, required = "required" })
                @Html.ValidationMessageFor(m => m.Description, null, new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.TestCode, new { @class = "form-label text-danger" })
                @Html.TextAreaFor(m => m.TestCode, new { @class = "form-control bg-black text-white", rows = 5, required = "required" })
                <small class="text-muted">Например: function sum(a,b) { return a+b; }</small>
                @Html.ValidationMessageFor(m => m.TestCode, null, new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.ExpectedOutput, new { @class = "form-label text-danger" })
                @Html.TextBoxFor(m => m.ExpectedOutput, new { @class = "form-control bg-black text-white", required = "required" })
                <small class="text-muted">Например: 5</small>
                @Html.ValidationMessageFor(m => m.ExpectedOutput, null, new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                @Html.LabelFor(m => m.Difficulty, new { @class = "form-label text-danger" })
                @Html.DropDownListFor(m => m.Difficulty, new SelectList(new[] { 1, 2, 3, 4, 5 }), new { @class = "form-control bg-black text-white" })
                @Html.ValidationMessageFor(m => m.Difficulty, null, new { @class = "text-danger" })
            </div>
            <div class="mb-3 form-check">
                @Html.CheckBoxFor(m => m.IsActive, new { @class = "form-check-input" })
                @Html.LabelFor(m => m.IsActive, new { @class = "form-check-label" })
            </div>
            <button type="submit" class="btn btn-danger w-100">➕ Добавить задание</button>
        }
    </div>
</div>