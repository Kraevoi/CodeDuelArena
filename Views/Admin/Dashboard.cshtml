@{
    ViewData["Title"] = "Admin Dashboard";
    var stats = ViewBag.Stats as CodeDuelArena.Controllers.AdminStats;
    var logs = ViewBag.Logs as List<CodeDuelArena.Data.AdminLogEntry>;
    var totalLosses = ViewBag.TotalLosses ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-danger fw-bold">👑 ADMIN DASHBOARD</h2>
    <div>
        <a href="/Admin/Users" class="btn btn-outline-danger me-2">👥 Users</a>
        <a href="/Admin/Quests" class="btn btn-outline-danger me-2">📋 Quests</a>
        <a href="/Admin/AddQuest" class="btn btn-outline-danger me-2">➕ Add Quest</a>
        <a href="/Admin/Logs" class="btn btn-outline-danger me-2">📜 Logs</a>
        <a href="/Admin/ExportUsers" class="btn btn-outline-info me-2">📥 Export CSV</a>
        <a href="/Admin/Logout" class="btn btn-danger">🚪 Exit</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-dark border-danger text-center">
            <div class="card-body">
                <h3 class="text-danger">@stats?.TotalUsers</h3>
                <p>Всего игроков</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-danger text-center">
            <div class="card-body">
                <h3 class="text-danger">@stats?.TotalScore</h3>
                <p>Всего очков</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-danger text-center">
            <div class="card-body">
                <h3 class="text-danger">@stats?.ActiveToday</h3>
                <p>Активны сегодня</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-dark border-danger text-center">
            <div class="card-body">
                <h3 class="text-danger">@stats?.TotalWins</h3>
                <p>Всего побед</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card bg-dark border-danger">
            <div class="card-header bg-danger">🏆 ТОП ИГРОК</div>
            <div class="card-body">
                @if (stats?.TopPlayer != null)
                {
                    <h4>@stats.TopPlayer.Username</h4>
                    <p>Очки: @stats.TopPlayer.Score | Победы: @stats.TopPlayer.Wins</p>
                }
                else
                {
                    <p>Нет игроков</p>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card bg-dark border-danger">
            <div class="card-header bg-danger">📊 СТАТИСТИКА</div>
            <div class="card-body">
                <p>Средний счет: @stats?.AverageScore.ToString("F0")</p>
                <p>Всего квестов: @stats?.TotalQuests</p>
                <p>Всего поражений: @totalLosses</p>
            </div>
        </div>
    </div>
</div>

<!-- ШАГ 13.1 - ГРАФИК АКТИВНОСТИ -->
<div class="card bg-dark border-danger mt-4">
    <div class="card-header bg-danger">📈 АКТИВНОСТЬ ПОЛЬЗОВАТЕЛЕЙ (НОВЫЕ РЕГИСТРАЦИИ)</div>
    <div class="card-body">
        <canvas id="activityChart" width="400" height="200"></canvas>
    </div>
</div>

<div class="card bg-dark border-danger mt-4">
    <div class="card-header bg-danger">📜 ПОСЛЕДНИЕ ЛОГИ</div>
    <div class="card-body" style="max-height: 300px; overflow-y: auto;">
        @if (logs != null && logs.Any())
        {
            <table class="table table-dark table-sm">
                <thead>
                    <tr><th>Время</th><th>Действие</th><th>Детали</th></tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        <tr><td>@log.Timestamp.ToString("HH:mm:ss")</td><td>@log.Action</td><td>@log.Details</td></tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Нет логов</p>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Загружаем данные для графика
    fetch('/Admin/Statistics')
        .then(res => res.json())
        .then(data => {
            if (data.usersByDay && data.usersByDay.length > 0) {
                const ctx = document.getElementById('activityChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: data.usersByDay.map(d => {
                            let date = new Date(d.date);
                            return date.toLocaleDateString('ru-RU');
                        }),
                        datasets: [{ 
                            label: 'Новые пользователи', 
                            data: data.usersByDay.map(d => d.count), 
                            borderColor: '#dc3545',
                            backgroundColor: 'rgba(220, 53, 69, 0.1)',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { 
                                labels: { color: 'white' } 
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.parsed.y + ' новых пользователей';
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                ticks: { color: 'white', stepSize: 1 },
                                grid: { color: 'rgba(255,255,255,0.1)' }
                            },
                            x: {
                                ticks: { color: 'white', rotation: 45, maxRotation: 45 },
                                grid: { color: 'rgba(255,255,255,0.1)' }
                            }
                        }
                    }
                });
            } else {
                document.getElementById('activityChart').parentElement.innerHTML = '<p class="text-muted text-center">Недостаточно данных для графика</p>';
            }
        })
        .catch(err => {
            console.error('Ошибка загрузки статистики:', err);
            document.getElementById('activityChart').parentElement.innerHTML = '<p class="text-danger text-center">Ошибка загрузки данных</p>';
        });
</script>