@{
    ViewData["Title"] = "Admin Dashboard";
    var stats = ViewBag.Stats;
    var logs = ViewBag.Logs as List<CodeDuelArena.Data.AdminLogEntry>;
}

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">👑 ADMIN DASHBOARD</h2>
    <div>
        <a href="/Admin/Users" class="btn btn-outline-danger">Users</a>
        <a href="/Admin/Quests" class="btn btn-outline-danger">Quests</a>
        <a href="/Admin/AddQuest" class="btn btn-outline-danger">Add Quest</a>
        <a href="/Admin/Logs" class="btn btn-outline-danger">Logs</a>
        <a href="/Admin/ExportUsers" class="btn btn-outline-info">Export CSV</a>
        <a href="/Admin/Logout" class="btn btn-danger">Exit</a>
    </div>
</div>

@if (stats != null)
{
    <div class="row mb-4">
        <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@stats.TotalUsers</h3><p>Всего игроков</p></div></div></div>
        <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@stats.TotalScore</h3><p>Всего очков</p></div></div></div>
        <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@stats.ActiveToday</h3><p>Активны сегодня</p></div></div></div>
        <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@stats.TotalWins</h3><p>Всего побед</p></div></div></div>
    </div>
}

<div class="card bg-dark mb-4">
    <div class="card-header bg-danger">📜 ПОСЛЕДНИЕ ЛОГИ</div>
    <div class="card-body" style="max-height: 300px; overflow: auto;">
        @if (logs != null && logs.Any())
        {
            <table class="table table-dark table-sm">
                <thead><tr><th>Время</th><th>Действие</th><th>Детали</th></tr></thead>
                <tbody>
                    @foreach(var log in logs)
                    {
                        <tr><td>@log.Timestamp.ToString("HH:mm:ss")</td><td>@log.Action</td><td>@log.Details</td></tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Нет логов</p>
        }
    </div>
</div>

<canvas id="activityChart" height="100"></canvas>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    fetch('/Admin/Statistics')
        .then(res => res.json())
        .then(data => {
            if (data.usersByDay && data.usersByDay.length > 0) {
                new Chart(document.getElementById('activityChart'), {
                    type: 'line',
                    data: { 
                        labels: data.usersByDay.map(d => d.date.split('T')[0]), 
                        datasets: [{ label: 'Новые пользователи', data: data.usersByDay.map(d => d.count), borderColor: '#dc3545', fill: true }] 
                    }
                });
            }
        });
</script>