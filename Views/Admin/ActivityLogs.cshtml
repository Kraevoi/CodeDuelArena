@model List<CodeDuelArena.Models.ActivityLog>
@{
    ViewData[""Title""] = ""Activity Logs"";
}
<h2 class=""text-danger"">Логи активности</h2>
<table class=""table table-dark"">
    <thead><tr><th>ID</th><th>Пользователь</th><th>Действие</th><th>Детали</th><th>Время</th><th>IP</th></tr></thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr><td>@log.Id</td><td>@log.UserName</td><td>@log.Action</td><td>@log.Details</td>
            <td>@log.Timestamp.ToString(""dd.MM.yyyy HH:mm:ss"")</td><td>@log.IpAddress</td></tr>
        }
    </tbody>
</table>
