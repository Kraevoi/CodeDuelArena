<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeDuel Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #0a0a0a; color: #fff; font-family: 'Courier New', monospace; }
        .admin-sidebar { position: fixed; left: 0; top: 0; width: 280px; height: 100%; background: #000; border-right: 2px solid #dc3545; padding-top: 20px; z-index: 1000; overflow-y: auto; }
        .admin-sidebar a { display: block; padding: 12px 20px; color: #fff; text-decoration: none; transition: 0.3s; }
        .admin-sidebar a:hover { background: #dc3545; color: #fff; }
        .admin-sidebar a.active { background: #dc3545; }
        .admin-sidebar .sidebar-header { text-align: center; padding: 20px; border-bottom: 1px solid #dc3545; margin-bottom: 20px; }
        .admin-content { margin-left: 280px; padding: 20px; }
        @if (ViewBag.CustomCss != null) { @Html.Raw(ViewBag.CustomCss) }
    </style>
</head>
<body>
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h3 class="text-danger">⚡ CODE DUEL</h3>
            <small class="text-muted">Admin Panel</small>
        </div>
        <a href="/Admin/Dashboard" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="fas fa-chart-line"></i> Dashboard
        </a>
        <a href="/Admin/Users" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
            <i class="fas fa-users"></i> Пользователи
        </a>
        <a href="/Admin/Quests" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Quests" ? "active" : "")">
            <i class="fas fa-tasks"></i> Квесты
        </a>
        <a href="/Admin/AddQuest" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AddQuest" ? "active" : "")">
            <i class="fas fa-plus-circle"></i> Добавить квест
        </a>
        <a href="/Admin/DuelTasks" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "DuelTasks" ? "active" : "")">
            <i class="fas fa-sword"></i> Задания дуэлей
        </a>
        <a href="/Admin/Complaints" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Complaints" ? "active" : "")">
            <i class="fas fa-bug"></i> Жалобы
        </a>
        <a href="/Admin/ActivityLogs" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ActivityLogs" ? "active" : "")">
            <i class="fas fa-history"></i> Логи
        </a>
        <a href="/Admin/Logout" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Logout" ? "active" : "")">
            <i class="fas fa-sign-out-alt"></i> Выход
        </a>
    </div>
    <div class="admin-content">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>