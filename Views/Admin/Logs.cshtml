@model List<CodeDuelArena.Data.AdminLogEntry>
@{
    ViewData["Title"] = "Logs";
}

<h2 class="text-danger">📜 ЛОГИ АКТИВНОСТИ</h2>
<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>

<table class="table table-dark table-striped">
    <thead class="bg-danger"><tr><th>ID</th><th>Время</th><th>Действие</th><th>Админ</th><th>Детали</th></tr></thead>
    <tbody>
        @foreach(var log in Model)
        {
            <tr><td>@log.Id</td><td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td><td>@log.Action</td><td>@log.AdminName</td><td>@log.Details</td></tr>
        }
    </tbody>
</table>