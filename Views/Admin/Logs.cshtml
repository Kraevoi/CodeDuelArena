@model List<CodeDuelArena.Data.AdminLogEntry>
@{
    ViewData["Title"] = "Admin Logs";
}

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger fw-bold">📜 ЛОГИ АКТИВНОСТИ</h2>
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<div class="card bg-dark border-danger">
    <div class="card-body" style="max-height: 500px; overflow-y: auto;">
        <table class="table table-dark table-striped">
            <thead class="bg-danger">
                <tr><th>ID</th><th>Время</th><th>Действие</th><th>Админ</th><th>Детали</th></tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>@log.Id</td>
                        <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        <td><span class="badge bg-info">@log.Action</span></td>
                        <td>@log.AdminName</td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>