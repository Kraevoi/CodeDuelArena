@model List<CodeDuelArena.Models.ActivityLog>
@{
    ViewData["Title"] = "All Logs";
}

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">📋 ВСЕ ЛОГИ АКТИВНОСТИ</h2>
    <a href="/Admin/ActivityLogs" class="btn btn-outline-info me-2">← Последние 200</a>
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<div class="table-responsive">
    <table class="table table-dark table-striped">
        <thead class="bg-danger text-white">
            <tr>
                <th>ID</th>
                <th>Пользователь</th>
                <th>Действие</th>
                <th>Детали</th>
                <th>Время</th>
                <th>IP адрес</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.Id</td>
                    <td>@log.UserName</td>
                    <td>@log.Action</td>
                    <td>@log.Details</td>
                    <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                    <td>@log.IpAddress</td>
                </tr>
            }
        </tbody>
    </table>
</div>