@model CodeDuelArena.Models.UserSettings
@{
    ViewData["Title"] = "Настройки";
}

<h2 class="text-danger">⚙️ Настройки</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card bg-dark border-danger mb-4">
            <div class="card-header bg-danger">🎨 Тема</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" data-theme="dark">🌙 Dark</button>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" data-theme="light">☀️ Light</button>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" data-theme="matrix">💚 Matrix</button>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-outline-danger w-100" data-theme="cyber">🔮 Cyber</button>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card bg-dark border-danger">
            <div class="card-header bg-danger">🎨 Кастомный CSS</div>
            <div class="card-body">
                <textarea id="customCss" class="form-control bg-black text-white" rows="10" placeholder="body { background: #000; }">@Model.CustomCss</textarea>
                <button class="btn btn-danger mt-2 w-100" id="saveCssBtn">Сохранить CSS</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        $("[data-theme]").click(function() {
            var theme = $(this).data("theme");
            $.post("/Settings/UpdateTheme", { theme: theme }, function(data) {
                if (data.success) {
                    applyTheme(theme);
                }
            });
        });
        
        $("#saveCssBtn").click(function() {
            var css = $("#customCss").val();
            $.post("/Settings/UpdateCustomCss", { customCss: css }, function(data) {
                if (data.success) {
                    applyCustomCss(css);
                    alert("CSS сохранен!");
                }
            });
        });
    });
    
    function applyTheme(theme) {
        var themes = {
            dark: {
                bg: "linear-gradient(135deg, #0a0a0a 0%, #1a0a0a 100%)",
                color: "#fff",
                cardBg: "#111"
            },
            light: {
                bg: "linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%)",
                color: "#000",
                cardBg: "#fff"
            },
            matrix: {
                bg: "#000",
                color: "#0f0",
                cardBg: "#0a0a0a"
            },
            cyber: {
                bg: "linear-gradient(135deg, #0a0a2a 0%, #1a0a3a 100%)",
                color: "#0ff",
                cardBg: "#0a0a2a"
            }
        };
        
        var t = themes[theme] || themes.dark;
        document.body.style.background = t.bg;
        document.body.style.color = t.color;
        document.cookie = "user_theme=" + theme + "; path=/; max-age=" + (365 * 24 * 60 * 60);
    }
    
    function applyCustomCss(css) {
        var styleId = "custom-theme";
        var existing = $("#" + styleId);
        if (existing.length) existing.remove();
        $("<style id='" + styleId + "'>" + css + "</style>").appendTo("head");
    }
    
    // Применить сохраненную тему при загрузке
    $.get("/Settings/GetTheme", function(data) {
        if (data.theme) {
            applyTheme(data.theme);
        }
    });
    
    // Применить сохраненный CSS при загрузке
    @if (!string.IsNullOrEmpty(Model.CustomCss))
    {
        @:applyCustomCss(`@Html.Raw(Model.CustomCss)`);
    }
</script>