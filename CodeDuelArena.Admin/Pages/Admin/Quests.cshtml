@page "/Admin/Quests"
@model CodeDuelArena.Admin.Pages.Admin.QuestsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quests";
}

<h2 class="text-danger">📋 УПРАВЛЕНИЕ КВЕСТАМИ</h2>
<div class="mb-3"><a href="/Admin/AddQuest" class="btn btn-danger">➕ Добавить</a> <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a></div>

<table class="table table-dark table-striped">
    <thead><tr><th>ID</th><th>Название</th><th>Тип</th><th>Очки</th><th>Действие</th></tr></thead>
    <tbody>
        @foreach (var q in Model.Quests)
        {
            <tr><td>@q.Id</td><td>@q.Title</td><td>@q.Type</td><td>@q.Points</td>
                <td><button class="btn btn-sm btn-danger" onclick="deleteQuest(@q.Id)">Удалить</button></td>
            </tr>
        }
    </tbody>
</table>

<script>
    function deleteQuest(id) { if(confirm('Удалить?')) $.post('/Admin/Quests?handler=Delete', {id}, d => { if(d.success) location.reload(); }); }
</script>