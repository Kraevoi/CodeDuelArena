@page "/Admin/AddDuelTask"
@model CodeDuelArena.Admin.Pages.Admin.AddDuelTaskModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Add Duel Task";
}

<h2 class="text-danger">➕ ДОБАВЛЕНИЕ ЗАДАНИЯ ДЛЯ ДУЭЛИ</h2>
<a href="/Admin/DuelTasks" class="btn btn-outline-danger mb-3">← Назад</a>

<div class="card bg-dark">
    <div class="card-body">
        <form method="post">
            <div class="mb-3"><label class="form-label text-danger">Название</label><input asp-for="Task.Title" class="form-control bg-black text-white" required /></div>
            <div class="mb-3"><label class="form-label text-danger">Описание</label><textarea asp-for="Task.Description" class="form-control bg-black text-white" rows="3" required></textarea></div>
            <div class="mb-3"><label class="form-label text-danger">Тестовый код</label><textarea asp-for="Task.TestCode" class="form-control bg-black text-white" rows="5" required></textarea></div>
            <div class="mb-3"><label class="form-label text-danger">Ожидаемый вывод</label><input asp-for="Task.ExpectedOutput" class="form-control bg-black text-white" required /></div>
            <div class="mb-3"><label class="form-label text-danger">Сложность (1-5)</label><input asp-for="Task.Difficulty" type="number" min="1" max="5" class="form-control bg-black text-white" value="1" /></div>
            <div class="mb-3 form-check"><input asp-for="Task.IsActive" class="form-check-input" checked /><label class="form-check-label">Активно</label></div>
            <button type="submit" class="btn btn-danger w-100">➕ Добавить</button>
        </form>
    </div>
</div>