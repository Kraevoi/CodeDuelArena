@page "/Admin/Complaints"
@model CodeDuelArena.Admin.Pages.Admin.ComplaintsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Complaints";
}

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">📢 ЖАЛОБЫ ПОЛЬЗОВАТЕЛЕЙ</h2>
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

@if (!Model.Complaints.Any())
{
    <div class="alert alert-info">Нет жалоб</div>
}
else
{
    <table class="table table-dark table-striped">
        <thead><tr><th>ID</th><th>Пользователь</th><th>Сообщение</th><th>Дата</th><th>Статус</th><th>Действия</th></tr></thead>
        <tbody>
            @foreach (var c in Model.Complaints)
            {
                <tr>
                    <td>@c.Id</td><td>@c.UserName</td><td>@c.Message</td><td>@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(c.IsRead ? "✅ Прочитано" : "🆕 Новое")</td>
                    <td>
                        @if (!c.IsRead) { <button class="btn btn-sm btn-success me-1" onclick="markRead(@c.Id)">✓</button> }
                        <button class="btn btn-sm btn-danger" onclick="deleteComplaint(@c.Id)">🗑</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    function markRead(id) { $.post('/Admin/Complaints?handler=MarkRead', {id}, d => { if(d.success) location.reload(); }); }
    function deleteComplaint(id) { if(confirm('Удалить?')) $.post('/Admin/Complaints?handler=Delete', {id}, d => { if(d.success) location.reload(); }); }
</script>