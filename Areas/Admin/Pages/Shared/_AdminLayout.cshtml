<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #0a0a0a 0%, #1a0a0a 100%); color: #fff; font-family: 'Courier New', monospace; }
        .navbar { border-bottom: 2px solid #dc3545; background: #000 !important; }
        .card { background: #111; border: 1px solid #dc3545; }
        .btn-danger { background: #dc3545; border: none; font-weight: bold; }
        .btn-outline-danger { border: 1px solid #dc3545; color: #dc3545; }
        .btn-outline-danger:hover { background: #dc3545; color: #fff; }
        .form-control { background: #000; color: #fff; border: 1px solid #dc3545; }
        .table { color: #fff; }
        .table thead th { background: #dc3545; color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark">
        <div class="container-fluid">
            <span class="navbar-brand text-danger fw-bold fs-3"><i class="fas fa-shield-alt"></i> ADMIN PANEL</span>
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", false)
</body>
</html>