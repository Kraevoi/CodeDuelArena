@page "/Admin"
@model CodeDuelArena.Areas.Admin.Pages.LoginModel
@{ Layout = null; }
<!DOCTYPE html>
<html><head><title>Admin Login</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>body{background:linear-gradient(135deg,#0a0a0a 0%,#1a0a0a 100%);color:#fff;font-family:monospace}.card{background:#111;border:1px solid #dc3545}.btn-danger{background:#dc3545;border:none;font-weight:bold}.form-control{background:#000;color:#fff;border:1px solid #dc3545}</style>
</head><body><div class="container"><div class="row justify-content-center mt-5"><div class="col-md-4"><div class="card border-danger">
<div class="card-header bg-danger text-center text-white"><h4>🔐 ADMIN PANEL</h4></div><div class="card-body">
@if(!string.IsNullOrEmpty(Model.ErrorMessage)){<div class="alert alert-danger">@Model.ErrorMessage</div>}
<form method="post"><input type="password" asp-for="Password" class="form-control mb-3" placeholder="Admin Password" required>
<div class="form-check mb-3"><input type="checkbox" asp-for="RememberMe" class="form-check-input"><label class="form-check-label">Запомнить меня</label></div>
<button type="submit" class="btn btn-danger w-100">Войти</button></form>
</div></div></div></div></div></body></html>