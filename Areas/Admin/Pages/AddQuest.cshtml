@page "/Admin/AddQuest"
@model CodeDuelArena.Areas.Admin.Pages.AddQuestModel
@{ ViewData["Title"] = "Add Quest"; }

<h2 class="text-danger">➕ ДОБАВЛЕНИЕ КВЕСТА</h2>
<a href="/Admin/Quests" class="btn btn-outline-danger mb-3">← Назад</a>

<div class="card bg-dark border-danger">
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label text-danger">Название</label>
                <input asp-for="Quest.Title" class="form-control bg-black text-white" required />
            </div>
            <div class="mb-3">
                <label class="form-label text-danger">Тип</label>
                <select asp-for="Quest.Type" class="form-control bg-black text-white">
                    <option value="LegacyFix">LegacyFix (исправить код)</option>
                    <option value="Hack">Hack (взломать)</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label text-danger">Описание</label>
                <textarea asp-for="Quest.Description" class="form-control bg-black text-white" rows="3" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label text-danger">Legacy код (с ошибками)</label>
                <textarea asp-for="Quest.LegacyCode" class="form-control bg-black text-white" rows="5" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label text-danger">Правильное решение</label>
                <textarea asp-for="Quest.SolutionCode" class="form-control bg-black text-white" rows="5" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label text-danger">Очки за выполнение</label>
                <input asp-for="Quest.Points" type="number" class="form-control bg-black text-white" value="100" required />
            </div>
            <button type="submit" class="btn btn-danger w-100">➕ Добавить квест</button>
        </form>
    </div>
</div>