@page "/Admin/Quests"
@model CodeDuelArena.Areas.Admin.Pages.QuestsModel
@{ ViewData["Title"] = "Quests"; }

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">📋 УПРАВЛЕНИЕ КВЕСТАМИ</h2>
    <div>
        <a href="/Admin/AddQuest" class="btn btn-danger me-2">➕ Добавить квест</a>
        <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<table class="table table-dark table-striped">
    <thead>
        <tr><th>ID</th><th>Название</th><th>Тип</th><th>Очки</th><th>Действия</th></tr>
    </thead>
    <tbody>
        @foreach (var q in Model.Quests)
        {
            <tr>
                <td>@q.Id</td>
                <td>@q.Title</td>
                <td><span class="badge bg-@(q.Type == "LegacyFix" ? "danger" : "primary")">@q.Type</span></td>
                <td>@q.Points</td>
                <td>
                    <button class="btn btn-sm btn-danger" onclick="deleteQuest(@q.Id)">🗑 Удалить</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function deleteQuest(id) {
        if (confirm('Удалить квест?')) {
            $.post('/Admin/Quests?handler=Delete', { id: id }, function(data) {
                if (data.success) location.reload();
            });
        }
    }
</script>