@page "/Admin/Users"
@model CodeDuelArena.Areas.Admin.Pages.UsersModel
@{ ViewData["Title"] = "Users"; }
<h2 class="text-danger">👥 УПРАВЛЕНИЕ ПОЛЬЗОВАТЕЛЯМИ</h2>
<a href="/Admin/Dashboard" class="btn btn-outline-danger mb-3">← Назад</a>
<table class="table table-dark table-striped">
    <thead><tr><th>ID</th><th>Имя</th><th>Email</th><th>Очки</th><th>Победы</th><th>Поражения</th><th>Действие</th></tr></thead>
    <tbody>
        @foreach (var u in Model.Users)
        {
            <tr><td>@u.Id</td><td>@u.Username</td><td>@u.Email</td><td class="text-danger fw-bold">@u.Score</td><td>@u.Wins</td><td>@u.Losses</td>
                <td><button class="btn btn-sm btn-danger" onclick="deleteUser(@u.Id)">Удалить</button></td>
            </tr>
        }
    </tbody>
</table>
<script>function deleteUser(id){if(confirm('Удалить?'))$.post('/Admin/Users?handler=Delete',{id},d=>{if(d.success)location.reload()});}</script>