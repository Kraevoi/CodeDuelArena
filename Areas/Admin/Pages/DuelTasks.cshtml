@page "/Admin/DuelTasks"
@model CodeDuelArena.Areas.Admin.Pages.DuelTasksModel
@{ ViewData["Title"] = "Duel Tasks"; }

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">⚔️ ЗАДАНИЯ ДЛЯ ДУЭЛЕЙ</h2>
    <div>
        <a href="/Admin/AddDuelTask" class="btn btn-danger me-2">➕ Добавить задание</a>
        <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
    </div>
</div>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<table class="table table-dark table-striped">
    <thead>
        <tr><th>ID</th><th>Название</th><th>Описание</th><th>Сложность</th><th>Статус</th><th>Действия</th></tr>
    </thead>
    <tbody>
        @foreach (var t in Model.Tasks)
        {
            <tr>
                <td>@t.Id</td>
                <td>@t.Title</td>
                <td>@t.Description</td>
                <td>@t.Difficulty ★</td>
                <td>@(t.IsActive ? "✅ Активно" : "⛔ Отключено")</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" onclick="toggleTask(@t.Id)">🔄 Перекл</button>
                    <button class="btn btn-sm btn-danger" onclick="deleteTask(@t.Id)">🗑 Удалить</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function toggleTask(id) {
        $.post('/Admin/DuelTasks?handler=Toggle', { id: id }, function(data) {
            if (data.success) location.reload();
        });
    }
    function deleteTask(id) {
        if (confirm('Удалить задание?')) {
            $.post('/Admin/DuelTasks?handler=Delete', { id: id }, function(data) {
                if (data.success) location.reload();
            });
        }
    }
</script>