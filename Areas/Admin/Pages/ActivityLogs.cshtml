@page "/Admin/ActivityLogs"
@model CodeDuelArena.Areas.Admin.Pages.ActivityLogsModel
@{ ViewData["Title"] = "Activity Logs"; }

<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">📜 ЛОГИ АКТИВНОСТИ</h2>
    <a href="/Admin/Dashboard" class="btn btn-outline-danger">← Назад</a>
</div>

<table class="table table-dark table-striped">
    <thead>
        <tr><th>ID</th><th>Пользователь</th><th>Действие</th><th>Детали</th><th>Время</th><th>IP</th></tr>
    </thead>
    <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.Id</td>
                <td>@log.UserName</td>
                <td>@log.Action</td>
                <td>@log.Details</td>
                <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td>@log.IpAddress</td>
            </tr>
        }
    </tbody>
</table>