@page "/Admin/Dashboard"
@model CodeDuelArena.Areas.Admin.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}
<div class="d-flex justify-content-between mb-4">
    <h2 class="text-danger">👑 ADMIN DASHBOARD</h2>
    <div>
        <a href="/Admin/Complaints" class="btn btn-warning me-2 position-relative">
            📢 Жалобы
            @if (Model.UnreadComplaints > 0)
            {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @Model.UnreadComplaints
            </span>
            }
        </a>
        <a href="/Admin/DuelTasks" class="btn btn-outline-warning me-2">⚔️ Duel Tasks</a>
        <a href="/Admin/ActivityLogs" class="btn btn-outline-info me-2">📜 Логи</a>
        <a href="/Admin/Users" class="btn btn-outline-danger me-2">👥 Users</a>
        <a href="/Admin/Quests" class="btn btn-outline-danger me-2">📋 Quests</a>
        <a href="/Admin?handler=Logout" class="btn btn-danger">🚪 Exit</a>
    </div>
</div>
<div class="row mb-4">
    <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@Model.TotalUsers</h3><p>Всего игроков</p></div></div></div>
    <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@Model.TotalScore</h3><p>Всего очков</p></div></div></div>
    <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@Model.ActiveToday</h3><p>Активны сегодня</p></div></div></div>
    <div class="col-md-3"><div class="card bg-dark text-center"><div class="card-body"><h3 class="text-danger">@Model.TotalWins</h3><p>Всего побед</p></div></div></div>
</div>