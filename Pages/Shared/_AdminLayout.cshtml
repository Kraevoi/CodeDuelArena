<!DOCTYPE html>
<html lang=""ru"">
<head>
    <meta charset=""utf-8"" />
    <meta name=""viewport"" content=""width=device-width, initial-scale=1.0"" />
    <title>@ViewData[""Title""] - Admin</title>
    <link href=""https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"" rel=""stylesheet"">
    <link rel=""stylesheet"" href=""https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"">
    <style>
        body { background: #0a0a0a; color: #fff; font-family: 'Courier New', monospace; }
        .sidebar { position: fixed; left: 0; top: 0; width: 260px; height: 100%; background: #000; border-right: 2px solid #dc3545; padding-top: 20px; z-index: 1000; }
        .sidebar a { display: block; padding: 12px 20px; color: #fff; text-decoration: none; transition: 0.3s; }
        .sidebar a:hover { background: #dc3545; }
        .sidebar a.active { background: #dc3545; }
        .sidebar-header { text-align: center; padding: 20px; border-bottom: 1px solid #dc3545; margin-bottom: 20px; }
        .content { margin-left: 260px; padding: 20px; }
        .btn-danger { background: #dc3545; border: none; }
        .btn-danger:hover { background: #bb2d3b; }
        .table { color: #fff; }
        .table thead th { background: #dc3545; }
        .form-control { background: #000; color: #fff; border: 1px solid #dc3545; }
    </style>
</head>
<body>
    <div class=""sidebar"">
        <div class=""sidebar-header"">
            <h3 class=""text-danger"">⚡ ADMIN</h3>
            <small>CodeDuel Panel</small>
        </div>
        <a href=""/Admin/Dashboard"">📊 Dashboard</a>
        <a href=""/Admin/Users"">👥 Users</a>
        <a href=""/Admin/Quests"">📋 Quests</a>
        <a href=""/Admin/AddQuest"">➕ Add Quest</a>
        <a href=""/Admin/Complaints"">📢 Complaints</a>
        <a href=""/Admin/Logs"">📜 Logs</a>
        <a href=""/Admin/Logout"">🚪 Logout</a>
    </div>
    <div class=""content"">
        @RenderBody()
    </div>
    <script src=""https://code.jquery.com/jquery-3.6.0.min.js""></script>
    <script src=""https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js""></script>
    @await RenderSectionAsync(""Scripts"", required: false)
</body>
</html>
