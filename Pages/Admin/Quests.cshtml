@page
@using CodeDuelArena.Data
@inject AppDbContext Db
@{
    ViewData[""Title""] = ""Quests"";
    if (Request.Cookies[""admin_auth""] != ""true"") { Response.Redirect(""/Admin/Login""); return; }
    var quests = DataStorage.GetQuests();
}
<h2 class=""text-danger"">Квесты</h2>
<a href=""/Admin/AddQuest"" class=""btn btn-danger mb-3"">➕ Добавить квест</a>
<table class=""table table-dark"">
    <thead><tr><th>ID</th><th>Название</th><th>Тип</th><th>Очки</th><th></th></tr></thead>
    <tbody>
        @foreach (var q in quests)
        {
            <tr>
                <td>@q.Id</td
                <td>@q.Title</td
                <td>@q.Type</td
                <td>@q.Points</td
                <td><button class=""btn btn-sm btn-danger"" onclick=""deleteQuest(@q.Id)"">Удалить</button></td
            ?
        }
    </tbody>
</table>
<script>
function deleteQuest(id) {
    if(confirm(""Удалить квест?"")) {
        $.post(""/Admin/DeleteQuest"", { id: id }, () => location.reload());
    }
}
</script>
