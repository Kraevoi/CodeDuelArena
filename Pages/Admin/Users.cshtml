@page
@using CodeDuelArena.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@{
    ViewData[""Title""] = ""Users"";
    if (Request.Cookies[""admin_auth""] != ""true"") { Response.Redirect(""/Admin/Login""); return; }
    var sort = Request.Query[""sort""].ToString();
    if (string.IsNullOrEmpty(sort)) sort = ""name_asc"";
    var users = await Db.Users.ToListAsync();
    users = sort switch
    {
        ""name_asc"" => users.OrderBy(u => u.Username).ToList(),
        ""name_desc"" => users.OrderByDescending(u => u.Username).ToList(),
        ""date_asc"" => users.OrderBy(u => u.RegisteredAt).ToList(),
        ""date_desc"" => users.OrderByDescending(u => u.RegisteredAt).ToList(),
        ""score_asc"" => users.OrderBy(u => u.Score).ToList(),
        ""score_desc"" => users.OrderByDescending(u => u.Score).ToList(),
        _ => users.OrderBy(u => u.Username).ToList()
    };
}
<h2 class=""text-danger"">Пользователи</h2>
<div class=""mb-3"">
    <a href=""?sort=name_asc"" class=""btn btn-sm btn-outline-danger"">А→Я</a>
    <a href=""?sort=name_desc"" class=""btn btn-sm btn-outline-danger"">Я→А</a>
    <a href=""?sort=date_asc"" class=""btn btn-sm btn-outline-danger"">Дата ↑</a>
    <a href=""?sort=date_desc"" class=""btn btn-sm btn-outline-danger"">Дата ↓</a>
    <a href=""?sort=score_asc"" class=""btn btn-sm btn-outline-danger"">Рейтинг ↑</a>
    <a href=""?sort=score_desc"" class=""btn btn-sm btn-outline-danger"">Рейтинг ↓</a>
</div>
<table class=""table table-dark"">
    <thead>
        <tr><th>ID</th><th>Имя</th><th>Email</th><th>Очки</th><th>Победы</th><th>Поражения</th><th>Действие</th></tr>
    </thead>
    <tbody>
        @foreach (var u in users)
        {
            <tr>
                <td>@u.Id</td
                <td>@u.Username</td
                <td>@u.Email</td
                <td>@u.Score</td
                <td>@u.Wins</td
                <td>@u.Losses</td
                <td><button class=""btn btn-sm btn-danger"" onclick=""deleteUser(@u.Id)"">Удалить</button></td
            ?
        }
    </tbody>
</table>
<script>
function deleteUser(id) {
    if(confirm(""Удалить пользователя?"")) {
        $.post(""/Admin/DeleteUser"", { id: id }, () => location.reload());
    }
}
</script>
