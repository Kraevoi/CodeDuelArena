@page
@model CodeDuelArena.Models.QuestModel
@{
    ViewData[""Title""] = ""Add Quest"";
    if (Request.Cookies[""admin_auth""] != ""true"") { Response.Redirect(""/Admin/Login""); return; }
}
<h2 class=""text-danger"">Добавить квест</h2>
<form method=""post"">
    <div class=""mb-2""><label>Название</label><input name=""Title"" class=""form-control"" required /></div>
    <div class=""mb-2""><label>Тип</label><select name=""Type"" class=""form-control""><option>LegacyFix</option><option>Hack</option></select></div>
    <div class=""mb-2""><label>Описание</label><textarea name=""Description"" class=""form-control"" rows=""3"" required></textarea></div>
    <div class=""mb-2""><label>Код</label><textarea name=""LegacyCode"" class=""form-control"" rows=""5"" required></textarea></div>
    <div class=""mb-2""><label>Решение</label><textarea name=""SolutionCode"" class=""form-control"" rows=""5"" required></textarea></div>
    <div class=""mb-2""><label>Очки</label><input name=""Points"" type=""number"" class=""form-control"" required /></div>
    <button type=""submit"" class=""btn btn-danger"">Добавить</button>
</form>
@functions {
    public IActionResult OnPost(QuestModel model)
    {
        var quests = DataStorage.GetQuests();
        model.Id = quests.Any() ? quests.Max(q => q.Id) + 1 : 1;
        quests.Add(model);
        var json = Newtonsoft.Json.JsonConvert.SerializeObject(quests, Newtonsoft.Json.Formatting.Indented);
        System.IO.File.WriteAllText(""quests.json"", json);
        return RedirectToPage(""/Admin/Quests"");
    }
}
