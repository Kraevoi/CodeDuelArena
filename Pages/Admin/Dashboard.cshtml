@page
@using CodeDuelArena.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@{
    ViewData[""Title""] = ""Dashboard"";
    if (Request.Cookies[""admin_auth""] != ""true"") { Response.Redirect(""/Admin/Login""); return; }
    var users = await Db.Users.CountAsync();
    var complaints = await Db.Complaints.CountAsync();
    var logs = await Db.ActivityLogs.CountAsync();
}
<h2 class=""text-danger"">Dashboard</h2>
<div class=""row"">
    <div class=""col-md-4"">
        <div class=""card bg-dark text-center"">
            <div class=""card-body"">
                <h3 class=""text-danger"">@users</h3>
                <p>Пользователей</p>
            </div>
        </div>
    </div>
    <div class=""col-md-4"">
        <div class=""card bg-dark text-center"">
            <div class=""card-body"">
                <h3 class=""text-danger"">@complaints</h3>
                <p>Жалоб</p>
            </div>
        </div>
    </div>
    <div class=""col-md-4"">
        <div class=""card bg-dark text-center"">
            <div class=""card-body"">
                <h3 class=""text-danger"">@logs</h3>
                <p>Логов</p>
            </div>
        </div>
    </div>
</div>
