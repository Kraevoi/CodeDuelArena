<div class="modal fade" id="authModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white border-danger">
            <div class="modal-header border-danger">
                <h5 class="modal-title">🔐 Вход / Регистрация</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" id="authTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active text-dark bg-danger" data-bs-toggle="tab" data-bs-target="#loginTab">Вход</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link text-white" data-bs-toggle="tab" data-bs-target="#registerTab">Регистрация</button>
                    </li>
                </ul>
                <div class="tab-content mt-3">
                    <div class="tab-pane fade show active" id="loginTab">
                        <input type="text" id="loginUsername" class="form-control bg-black text-white border-danger mb-2" placeholder="Имя пользователя">
                        <input type="password" id="loginPassword" class="form-control bg-black text-white border-danger mb-2" placeholder="Пароль">
                        <div class="form-check mb-2">
                            <input type="checkbox" id="loginRemember" class="form-check-input">
                            <label class="form-check-label">Запомнить меня</label>
                        </div>
                        <button id="loginBtn" class="btn btn-danger w-100">Войти</button>
                    </div>
                    <div class="tab-pane fade" id="registerTab">
                        <input type="text" id="regUsername" class="form-control bg-black text-white border-danger mb-2" placeholder="Имя пользователя (мин. 3 символа)">
                        <input type="email" id="regEmail" class="form-control bg-black text-white border-danger mb-2" placeholder="Email">
                        <input type="password" id="regPassword" class="form-control bg-black text-white border-danger mb-2" placeholder="Пароль (мин. 4 символа)">
                        <div class="form-check mb-2">
                            <input type="checkbox" id="regRemember" class="form-check-input">
                            <label class="form-check-label">Запомнить меня</label>
                        </div>
                        <button id="registerBtnModal" class="btn btn-danger w-100">Зарегистрироваться</button>
                    </div>
                </div>
                <div id="authError" class="alert alert-danger mt-3 d-none"></div>
            </div>
        </div>
    </div>
</div>